# Key của gói OpenCode Go (https://opencode.ai -> workspace -> API Keys)
# QUAN TRỌNG: không commit key thật. Copy file này thành .env và điền key.
OPENCODE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# (tuỳ chọn) model mặc định — phải nằm trong gói Go
# glm-5 = đáng tin cho vòng lặp agent (multi-turn). kimi-k2.5 nhanh nhưng hỏng multi-turn.
TAW_MODEL=glm-5

# (tuỳ chọn) endpoint — mặc định đã đúng cho gói Go
# TAW_BASE_URL=https://opencode.ai/zen/go/v1

# (tuỳ chọn) giới hạn
# TAW_MAX_STEPS=40
# TAW_MAX_TOKENS=8192
