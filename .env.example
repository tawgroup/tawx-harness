# OpenCode Go plan key (https://opencode.ai -> workspace -> API Keys)
# IMPORTANT: never commit a real key. Copy this file to .env and fill it in.
OPENCODE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# (optional) default model — must be in the Go plan
# glm-5 = reliable for the agent loop (multi-turn). kimi-k2.5 is fast but breaks on multi-turn.
TAWX_MODEL=glm-5

# (optional) endpoint — already correct for the Go plan
# TAWX_BASE_URL=https://opencode.ai/zen/go/v1

# (optional) limits
# TAWX_MAX_STEPS=40
# TAWX_MAX_TOKENS=8192
# TAWX_REQUEST_TIMEOUT=180000
